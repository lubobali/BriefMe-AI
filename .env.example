# LLM Provider (anthropic or nvidia)
LLM_PROVIDER=anthropic
ANTHROPIC_BASE_URL=https://www.dataexpert.io/api/v1/anthropic
ANTHROPIC_API_KEY=sk-de-your-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Or NVIDIA NIM
NVIDIA_API_KEY=nvapi-your-key
NVIDIA_MODEL=nvidia/llama-3.1-nemotron-ultra-253b-v1

# Gmail OAuth (credentials.json from Google Cloud Console)
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json
GMAIL_APPROVED_SENDER=owner@example.com
GMAIL_RECIPIENT=your-email@example.com

# Langfuse (optional, for tracing)
LANGFUSE_SECRET_KEY=sk-lf-your-key
LANGFUSE_PUBLIC_KEY=pk-lf-your-key
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
